APP_ENV=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://memory:memory@localhost:5432/memory_db
SYNC_DATABASE_URL=postgresql+psycopg://memory:memory@localhost:5432/memory_db

MEMORY_ROOT_PATH=.
MEMORY_ACTIVE_PROJECT=
OBSIDIAN_VAULT_PATH=./knowledge/obsidian-vault
EMBEDDING_PROVIDER=local
EMBEDDING_DIMENSION=384
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

INDEXER_POLL_SECONDS=1.0
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_CHARS=200

API_HOST=0.0.0.0
API_PORT=8080
MCP_SERVER_NAME=memory-mcp
